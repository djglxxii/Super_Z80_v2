; Super_Z80 VDP include surface.

SZ_PORT_VDP_STATUS           EQU $E0
SZ_PORT_VDP_CONTROL          EQU $E1
SZ_PORT_VDP_DATA             EQU $E2
SZ_PORT_VDP_PALETTE_INDEX    EQU $E3
SZ_PORT_VDP_PALETTE_RED      EQU $E4
SZ_PORT_VDP_PALETTE_GREEN    EQU $E5
SZ_PORT_VDP_PALETTE_BLUE     EQU $E6
SZ_PORT_VDP_PALETTE_ALPHA    EQU $E7
SZ_PORT_VDP_BG_SCROLL_X      EQU $E8
SZ_PORT_VDP_BG_SCROLL_Y      EQU $E9
SZ_PORT_VDP_FG_SCROLL_X      EQU $EA
SZ_PORT_VDP_FG_SCROLL_Y      EQU $EB
SZ_PORT_VDP_BG_PATTERN_BANK  EQU $EC
SZ_PORT_VDP_FG_PATTERN_BANK  EQU $ED

SZ_VDP_STATUS_VBLANK         EQU $01
SZ_VDP_STATUS_FRAME_READY    EQU $02
SZ_VDP_STATUS_SPR_OVERFLOW   EQU $04
SZ_VDP_STATUS_SPR_COLLISION  EQU $08

SZ_VDP_PATTERN_BANK0_BASE    EQU $0000
SZ_VDP_PATTERN_BANK1_BASE    EQU $2000
SZ_VDP_BG_TILEMAP_BASE       EQU $4000
SZ_VDP_FG_TILEMAP_BASE       EQU $5000
SZ_VDP_SAT_BASE              EQU $6000

SZ_VDP_TILE_WIDTH            EQU 8
SZ_VDP_TILE_HEIGHT           EQU 8
SZ_VDP_TILE_BYTES            EQU 64
SZ_VDP_TILEMAP_WIDTH         EQU 32
SZ_VDP_TILEMAP_HEIGHT        EQU 24
SZ_VDP_TILEMAP_BYTES         EQU 768

 MACRO SZ_VDP_WRITE_IMM port, value
  ld a, value
  out (port), a
 ENDM

 MACRO SZ_VDP_SET_PALETTE_RGBA index_value, red_value, green_value, blue_value, alpha_value
  ld a, index_value
  out (SZ_PORT_VDP_PALETTE_INDEX), a
  ld a, red_value
  out (SZ_PORT_VDP_PALETTE_RED), a
  ld a, green_value
  out (SZ_PORT_VDP_PALETTE_GREEN), a
  ld a, blue_value
  out (SZ_PORT_VDP_PALETTE_BLUE), a
  ld a, alpha_value
  out (SZ_PORT_VDP_PALETTE_ALPHA), a
 ENDM
